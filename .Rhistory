Type_color <- function(type){
if (type == 1){
return ("red")
}
if (type == 2){
return ("green")
}
if (type == 3){
return ("orange")
}
if (type == 5){
return ("blue")
}
if (type == 6){
return ("pink")
}
if (type == 7){
return ("purple")
}
}
glass = read.csv("glass.csv")
glass_dist <- dist(glass[c(1:9)])
glass_mds <- cmdscale((glass_dist))
plot(glass_mds, col = Type_color(glass$Type))
