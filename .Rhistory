# Libraries
library(plotly)
df <- mtcars
range_min = vector("double", ncol(df))
range_max = vector("double", ncol(df))
labels = vector("character", ncol(df))
for (i in seq_along(df)) {
range_min[[i]] = min(df[[i]])
range_max[[i]] = max(df[[i]])
labels[[i]] = colnames(df)[i]
}
fig <- df %>% plot_ly(type = 'parcoords', labelangle=45,
main = "Parallel coordinates with gear count",
line = list(color = ~gear,
colorscale = 'Jet'),
dimensions = list(
list(range = c(range_min[1],range_max[1]),label = labels[1], values = ~mpg),
list(range = c(range_min[2],range_max[2]),label = labels[2], values = ~cyl),
list(range = c(range_min[3],range_max[3]),label = labels[3], values = ~disp),
list(range = c(range_min[4],range_max[4]),label = labels[4], values = ~hp),
list(range = c(range_min[5],range_max[5]),label = labels[5], values = ~drat),
list(range = c(range_min[6],range_max[6]),label = labels[6], values = ~wt),
list(range = c(range_min[7],range_max[7]),label = labels[7], values = ~qsec),
list(range = c(range_min[8],range_max[8]),label = labels[8], values = ~vs),
list(range = c(range_min[9],range_max[9]),label = labels[9], values = ~am),
list(range = c(range_min[11],range_max[11]),label = labels[11], values = ~carb)
)
)
fig
